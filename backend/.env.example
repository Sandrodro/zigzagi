# Backend config. Copy to .env and fill in. .env is gitignored.
DATABASE_URL=postgresql+psycopg://zigzagi:zigzagi@localhost:5432/zigzagi

# Gemini (server-side only; never shipped to the client)
GEMINI_API_KEY=
# Two models: DUMB (cheap/fast: extract, lemmatize) and SMART (clues, theme, word-check)
GEMINI_DUMB=gemini-3.5-flash
GEMINI_SMART=gemini-3.1-pro-preview
